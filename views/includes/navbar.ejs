<style>
  .search-btn {
  background-color: #fe424d;
  color: white;
  border-radius: 25px;
  padding: 8px 16px;
  border: none;
  display: flex;
  align-items: center;
  gap: 6px;
  font-weight: 500;
}

.search-btn:hover {
  background-color: #e31c5f;
  color: white;
}

.search-btn i {
  display: inline;
  margin-right: 0.3rem;
}

.search-inp {
  border-radius: 25px;
  padding: 0.5rem 3rem 0.5rem 3rem;
  border: 1px solid rgba(0, 0, 0, 0.384);
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 1rem;
  font-weight: 500;
}

</style>

<nav class="navbar navbar-expand-md border-bottom sticky-top fw-semibold">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler"
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
      </div>
      
<div class="navbar-nav ms-auto search-container">

  <form class="d-flex" role="search" action="/listings" method="GET">

    <input 
      class="form-control me-2 search-inp"
      type="search"
      placeholder="Search destinations"
      name="search"
      id="searchBox"
    />

    <button class="btn search-btn" type="submit">
      <i class="fa-solid fa-magnifying-glass"></i>
      Search
    </button>

  </form>

  <div id="suggestions" class="suggestions-box"></div>

</div>
      
         <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/listings/new">Airbnb your home</a>
        <% if(!currUser) { %>
          <a class="nav-link fw-medium" href="/signup"><b>Sign up</b></a>
          <a class="nav-link fw-medium" href="/login"><b>Log in</b></a>
        <% } %>

        <% if(currUser) { %>
          <a class="nav-link fw-medium" href="/logout"><b>Log out</b></a>
        <% } %>

        </div>
      </div>
    </div>
</nav>