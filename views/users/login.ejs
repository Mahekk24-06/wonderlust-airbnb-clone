<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-6 offset-3">
    <h3>Login on Wonderlust</h3>

    <form action="/login" method="POST">

      <div class="mb-3">
        <label class="form-label">Username</label>
        <input
          type="text"
          name="username"
          class="form-control"
          required
        >
      </div>

      <div class="mb-3">
        <label class="form-label">Password</label>
        <input
          type="password"
          name="password"
          class="form-control"
          required
        >
      </div>

      <button class="btn btn-success">Login</button>

    </form>
  </div>
</div>